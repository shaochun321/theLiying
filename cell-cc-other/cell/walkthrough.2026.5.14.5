            (f"ocr_{typ[0].lower()}_{adapter.adapter_name}_{k}", "candidate_p" if typ.startswith("P") else "candidate_r",
             k, ofs, jdump(members), score, real_transport_support, 0.0, 0.02*k, 1, "candidate", hid, now(), "derived_minimal", jdump({})))
             
