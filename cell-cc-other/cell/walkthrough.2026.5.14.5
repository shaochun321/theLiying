         drift_rho, drift_rho * 0.3, drift_rho * 0.1,
         drift_rho, converged, now()))

    return round_id, rho_all, {
        "xin_true": xin_true, "xin_pseudo": xin_pseudo, "xin_bg": xin_bg,
        "conservation_gap": conservation_gap, "chi_x": chi_x,
