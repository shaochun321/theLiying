            total_xin_end += rho.get("x_true", 0)
            total_absorbed_p += rho.get("p_band", 0) * 0.05
            total_resolved_r += rho.get("r_band", 0) * 0.03

    # 10. Xin ledger conservation (v37.4.19: use actual DB records)
