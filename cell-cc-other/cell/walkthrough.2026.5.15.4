def write_cells(conn, run_id, adapter, k, cells):
    from morphosphere.active_exec.runtime.spms.binding import SPMSBinder
    class MockGeo:
        def __init__(self, c):
            self.uid = c.uid
            self.position = (c.x, c.y, c.z)
