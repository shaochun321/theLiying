         jdump([cells[0].uid]), jdump([win_id]), abs(avg_V)*0.01, 0.5+0.02*k, n,
         "diagnostic", "ledger_audit", "refutation_while_synthetic", ts))

    # maturity_gate_record — query real transport support from P/R graph
