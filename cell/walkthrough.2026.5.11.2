                oh_winner = "B_inertia"; wins_b += 1
            else:
                oh_winner = "DRAW"  # within 20% tolerance
        else:
            oh_winner = "A_strata"; wins_a += 1

        # Final verdict: B must win ALL THREE
        if wins_b == 3:
            winner = "B_inertia"
            rationale = "Candidate B wins all 3 metrics: survival, latency, overhead"
        elif wins_b > wins_a:
            winner = "A_strata"
