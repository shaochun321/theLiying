		{"id":"dec2_b","type":"text","x":340,"y":250,"width":150,"height":35,"text":"⬜ 2A: 有丝分裂噪声\n3行代码","color":"4"},
		{"id":"dec2_c","type":"text","x":340,"y":300,"width":150,"height":35,"text":"⏸️ 2B: CPG相位锁\n推迟"},
